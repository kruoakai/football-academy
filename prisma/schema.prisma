datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum Role {
  ADMIN
  COACH
  GUARDIAN
  STUDENT
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  CANCELLED
}

enum BookingType {
  ACADEMY
  CLINIC
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  AWAITING_VERIFICATION
  PAID
  FAILED
}

enum ActivityType {
  PRACTICE
  MATCH
  CAMP
  ASSESSMENT
  CLINIC_GROUP
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum AttendanceMethod {
  QR
  MANUAL
}

enum PromotionType {
  DISCOUNT
  GIFT
}

enum CampaignChannel {
  EMAIL
  LINE
  BOTH
}

enum DiscountUnit {
  PERCENT
  AMOUNT
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  phone        String?  @unique
  passwordHash String
  role         Role
  active       Boolean  @default(true)
  leadSource   String?
  lineUserId   String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  guardian Guardian?
  coach    Coach?
  payments Payment[]
  passwordResetTokens PasswordResetToken[]
  articles Article[]

  @@map("users")
}

/// Token itself is only ever in the reset-link URL/email — the DB stores a
/// SHA-256 hash of it, so a DB leak alone can't be used to reset accounts.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

model Guardian {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  students Student[]

  @@map("guardians")
}

model Coach {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?
  specialty String?

  schedules CourseSchedule[]

  @@map("coaches")
}

model Course {
  id          String  @id @default(cuid())
  name        String
  ageGroup    String
  level       String?
  description String?
  price       Decimal @db.Decimal(10, 2)

  batches     Batch[]
  schedules   CourseSchedule[]
  enrollments Enrollment[]

  @@map("courses")
}

model Batch {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name        String
  startDate   DateTime
  endDate     DateTime
  sessionTime String

  schedules   CourseSchedule[]
  enrollments Enrollment[]
  students    Student[]
  activities  Activity[]

  @@map("batches")
}

model CourseSchedule {
  id       String  @id @default(cuid())
  courseId String
  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  batchId  String
  batch    Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  coachId  String
  coach    Coach   @relation(fields: [coachId], references: [id])
  day      String
  time     String
  venue    String

  bookings Booking[]

  @@map("course_schedules")
}

model Student {
  id             String  @id @default(cuid())
  userId         String? @unique
  guardianId     String
  guardian       Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  code           String  @unique
  name           String
  dob            DateTime
  level          String?
  injuryHistory  String?
  batchId        String?
  batch          Batch?  @relation(fields: [batchId], references: [id])
  createdAt      DateTime @default(now())

  enrollments   Enrollment[]
  bookings      Booking[]
  attendance    Attendance[]
  injuryRecords InjuryRecord[]

  @@map("students")
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id])
  batchId   String
  batch     Batch            @relation(fields: [batchId], references: [id])
  status    EnrollmentStatus @default(PENDING)
  startDate DateTime         @default(now())

  @@map("enrollments")
}

model ClinicService {
  id          String @id @default(cuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  durationMin Int

  bookings      Booking[]
  injuryRecords InjuryRecord[]

  @@map("clinic_services")
}

enum ClinicActivityCategory {
  ASSESSMENT
  TREATMENT
  FIELD
}

/// Content-showcase rows for the public /clinic page ("กิจกรรมคลินิกกายภาพและ
/// การบำบัดภาคสนาม" section) — admin-managed via /admin/clinic-activities.
/// FIELD-category rows do double duty: they power both the "ดูแลภาคสนาม"
/// hero section (alternating cards) AND appear as one of the 3 filter tabs
/// in the "กิจกรรมในคลินิก" grid below it.
model ClinicActivity {
  id        String                  @id @default(cuid())
  category  ClinicActivityCategory
  title     String
  caption   String
  imageUrl  String?
  sortOrder Int                     @default(0)
  published Boolean                 @default(true)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@map("clinic_activities")
}

/// Photo rows for the public /gallery page — admin-managed via /admin/gallery.
/// Each row requires an image (a gallery is nothing without one); caption is
/// optional. published + sortOrder control show/hide and display order,
/// same convention as ClinicActivity.
model GalleryPhoto {
  id        String   @id @default(cuid())
  caption   String?
  imageUrl  String
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_photos")
}

/// PDPA access-control note: this table is intentionally NOT legally reviewed yet
/// (see CLAUDE.md). Every read/write path MUST be gated to Role.ADMIN only —
/// do not relax this without a completed PDPA review.
model InjuryRecord {
  id              String         @id @default(cuid())
  studentId       String
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  clinicServiceId String?
  clinicService   ClinicService? @relation(fields: [clinicServiceId], references: [id])
  diagnosis       String
  treatmentNotes  String?
  date            DateTime       @default(now())
  recordedBy      String
  createdAt       DateTime       @default(now())

  @@map("injury_records")
}

model Promotion {
  id           String        @id @default(cuid())
  code         String        @unique
  type         PromotionType
  value        Decimal?      @db.Decimal(10, 2)
  discountUnit DiscountUnit?
  giftItem     String?
  giftStock    Int?
  targetGroup  String?
  validFrom    DateTime
  validTo      DateTime
  maxUses      Int?
  usedCount    Int           @default(0)
  active       Boolean       @default(true)
  // Whether this promotion is showcased on the public /register page — separate
  // from `active` so admin can hold codes back (e.g. staff/referral-only codes)
  // that still work at checkout but aren't advertised.
  showOnRegisterPage Boolean @default(false)
  createdAt    DateTime      @default(now())

  redemptions PromotionRedemption[]

  @@map("promotions")
}

model PromotionRedemption {
  id               String    @id @default(cuid())
  promotionId      String
  promotion        Promotion @relation(fields: [promotionId], references: [id])
  bookingId        String    @unique
  booking          Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  discountApplied  Decimal?  @db.Decimal(10, 2)
  createdAt        DateTime  @default(now())

  @@map("promotion_redemptions")
}

model Booking {
  id              String        @id @default(cuid())
  type            BookingType
  studentId       String
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scheduleId      String?
  schedule        CourseSchedule? @relation(fields: [scheduleId], references: [id])
  clinicServiceId String?
  clinicService   ClinicService? @relation(fields: [clinicServiceId], references: [id])
  date            DateTime
  status          BookingStatus @default(PENDING_PAYMENT)
  createdAt       DateTime      @default(now())

  payment            Payment?
  promotionRedemption PromotionRedemption?

  @@map("bookings")
}

model Payment {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  amount    Decimal       @db.Decimal(10, 2)
  method    String
  status    PaymentStatus @default(PENDING)

  // Bank-transfer / PromptPay slip verification flow
  slipUrl          String?
  slipSubmittedAt  DateTime?
  verifiedByUserId String?
  verifiedAt       DateTime?
  rejectedReason   String?

  bookingId String        @unique
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@map("payments")
}

model Activity {
  id       String       @id @default(cuid())
  name     String
  type     ActivityType
  batchId  String?
  batch    Batch?       @relation(fields: [batchId], references: [id])
  date     DateTime
  location String?

  attendance Attendance[]

  @@map("activities")
}

model Attendance {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  status     AttendanceStatus
  checkedBy  String
  checkedAt  DateTime         @default(now())
  method     AttendanceMethod

  @@unique([studentId, activityId])
  @@map("attendance")
}

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("articles")
}

model Campaign {
  id             String          @id @default(cuid())
  subject        String?
  message        String
  channel        CampaignChannel
  audience       String
  recipientCount Int
  sentBy         String
  sentAt         DateTime        @default(now())

  @@map("campaigns")
}

/// Singleton row (id is always "homepage") holding every editable text block
/// on the public landing page (src/app/page.tsx), so admins can update copy
/// without a code change. Defaults mirror the original hardcoded copy.
model HomePageContent {
  id String @id @default("homepage")

  showHeroBadge          Boolean @default(true)
  heroBadge              String @default("ยินผัน ฟุตบอล อคาเดมี")
  heroTitleLine1         String @default("สอนโดย")
  heroTitleHighlight1    String @default("ทีมชาติ")
  heroTitleLine2         String @default("ฟื้นฟูโดย")
  heroTitleHighlight2    String @default("มืออาชีพ")
  heroDescription        String @default("สถาบันฟุตบอลที่ดำเนินงานโดยคู่ครองผู้เชี่ยวชาญคนละด้าน ผสานการฝึกซ้อมจากอดีตนักเตะทีมชาติ เข้ากับการดูแลฟื้นฟูร่างกายจากนักกายภาพบำบัดมืออาชีพ ในสถาบันเดียว")
  heroCtaPrimaryLabel    String @default("สมัครเรียนวันนี้")
  heroCtaSecondaryLabel  String @default("รู้จักเรามากขึ้น")
  heroChip1Title         String @default("โค้ช + นักกายภาพ")
  heroChip1Desc          String @default("ทีมงานมืออาชีพในที่เดียว")
  showHeroChip1          Boolean @default(true)
  heroChip2Title         String @default("ฝึกซ้อม")
  heroChip2Desc          String @default("ทุกช่วงวัย")
  showHeroChip2          Boolean @default(true)
  heroChip3Title         String @default("ฟื้นฟู")
  heroChip3Desc          String @default("คลินิกกายภาพ")
  showHeroChip3          Boolean @default(true)
  // When any of these is set, the hero's visual side switches from the 3
  // text-chip cards to a training video + 4-photo-tile grid. URLs are
  // nullable (each piece can be filled in independently); labels always
  // have a value so a tile still shows sensible text before an image exists.
  heroVideoUrl   String?
  // Alternative to heroVideoUrl (uploaded file): a pasted YouTube/Facebook/TikTok
  // link, embedded client-side. Upload takes priority over this when both are set.
  heroVideoEmbedUrl String?
  heroTile1Url   String?
  heroTile1Label String  @default("เด็กเล็กฝึกทักษะ")
  heroTile2Url   String?
  heroTile2Label String  @default("แข่งขันรุ่นเยาวชน")
  heroTile3Url   String?
  heroTile3Label String  @default("คลินิกกายภาพ")
  heroTile4Url   String?
  heroTile4Label String  @default("โค้ชสอนเทคนิค")

  // Each section (and each repeated card within it) can be independently
  // hidden from the public page without deleting its saved text, so admins
  // can turn parts off/on without losing content to re-type later.
  showUspSection        Boolean @default(true)
  showUspSectionTitle    Boolean @default(true)
  uspSectionTitle    String @default("สองมืออาชีพ หนึ่งเป้าหมาย")
  showUspSectionSubtitle Boolean @default(true)
  uspSectionSubtitle String @default("ความเชี่ยวชาญที่แตกต่างกัน ผสานกันเพื่อพัฒนานักเรียนอย่างรอบด้าน")
  showUsp1           Boolean @default(true)
  usp1Tag            String @default("โค้ชหลัก")
  usp1Title          String @default("สอนโดยอดีตนักเตะทีมชาติ")
  usp1Name           String @default("ภานุวัฒน์ ยินผัน")
  usp1Desc           String @default("อดีตนักฟุตบอลทีมชาติไทย ติดทีมดาราเอเชีย (Asian All-Star) หลายสมัย ถ่ายทอดเทคนิคและประสบการณ์ระดับนานาชาติสู่นักเรียนทุกรุ่น")
  showUsp2           Boolean @default(true)
  usp2Tag            String @default("หัวหน้าคลินิก")
  usp2Title          String @default("ฟื้นฟูโดยมืออาชีพ")
  usp2Name           String @default("ผู้ร่วมก่อตั้ง / นักกายภาพบำบัด")
  usp2Desc           String @default("อดีตนักกายภาพบำบัดประจำทีมฟุตบอลหลายทีม ดูแลคลินิกกายภาพและฟื้นฟูของสถาบันโดยตรง ลดความเสี่ยงบาดเจ็บและเสริมสมรรถภาพนักกีฬา")

  showHighlightsSection  Boolean @default(true)
  showHighlightsSectionTitle Boolean @default(true)
  highlightsSectionTitle String @default("ทำไมต้องยินผัน ฟุตบอล อคาเดมี")
  showHighlight1         Boolean @default(true)
  highlight1Title        String @default("หลักสูตรตามช่วงวัย")
  highlight1Desc         String @default("ออกแบบการฝึกให้เหมาะกับพัฒนาการของนักเรียนแต่ละรุ่น ตั้งแต่ระดับเริ่มต้นถึงระดับแข่งขัน")
  showHighlight2         Boolean @default(true)
  highlight2Title        String @default("ดูแลครบวงจร")
  highlight2Desc         String @default("ฝึกซ้อมฟุตบอลควบคู่การประเมินร่างกายและฟื้นฟูอาการบาดเจ็บ โดยทีมงานเฉพาะทาง")
  showHighlight3         Boolean @default(true)
  highlight3Title        String @default("แจ้งเตือนผ่าน LINE")
  highlight3Desc         String @default("ตารางฝึกซ้อม การนัดหมาย และผลการเข้าเรียน แจ้งเตือนถึงผู้ปกครองแบบเรียลไทม์")

  showProgramsSection     Boolean @default(true)
  showProgramsSectionTitle Boolean @default(true)
  programsSectionTitle    String @default("คอร์สเรียนตามช่วงวัย")
  showProgramsSectionSubtitle Boolean @default(true)
  programsSectionSubtitle String @default("ตัวอย่างการจัดกลุ่มรุ่น — รายละเอียดคอร์สฉบับเต็มเร็วๆ นี้")
  showProgram1            Boolean @default(true)
  program1Age             String @default("6–9 ปี")
  program1Name            String @default("เยาวชนเริ่มต้น")
  program1Desc            String @default("ปูพื้นฐานทักษะบอลและความสนุกในการเล่น")
  showProgram2            Boolean @default(true)
  program2Age             String @default("10–13 ปี")
  program2Name            String @default("เยาวชนพัฒนา")
  program2Desc            String @default("พัฒนาเทคนิคเฉพาะตำแหน่งและการอ่านเกม")
  showProgram3            Boolean @default(true)
  program3Age             String @default("14–18 ปี")
  program3Name            String @default("เยาวชนสู่ทีมชาติ")
  program3Desc            String @default("ยกระดับสู่การแข่งขันและเตรียมความพร้อมสู่ทีมระดับสูง")

  showArticlesSection Boolean @default(true)

  showCtaSection Boolean @default(true)
  showCtaTitle   Boolean @default(true)
  ctaTitle       String @default("พร้อมให้ลูกของคุณก้าวสู่สนามหญ้าแล้วหรือยัง?")
  ctaDescription String @default("สมัครเรียนวันนี้ พร้อมรับการดูแลจากทีมโค้ชและนักกายภาพบำบัดมืออาชีพ")
  ctaButtonLabel String @default("เริ่มต้นเลย")

  updatedAt DateTime @updatedAt

  @@map("home_page_content")
}

/// Singleton row (id is always "about") holding every editable text block on
/// the public /about page (src/app/about/page.tsx), mirroring HomePageContent's
/// pattern: independent show/hide toggles per section/card alongside the text.
model AboutPageContent {
  id String @id @default("about")

  showHeroBadge   Boolean @default(true)
  heroBadge       String  @default("เกี่ยวกับเรา")
  heroTitle       String  @default("สองความเชี่ยวชาญ หนึ่งความตั้งใจ เพื่อนักเตะรุ่นใหม่")
  heroDescription String  @default("ยินผัน ฟุตบอล อคาเดมี ก่อตั้งโดยคู่ครองที่เชี่ยวชาญคนละด้าน ฝั่งหนึ่งคืออดีตนักเตะทีมชาติผู้เข้าใจเกมลูกหนังอย่างลึกซึ้ง อีกฝั่งคือนักกายภาพบำบัดมืออาชีพผู้ดูแลร่างกายนักกีฬามาแล้วนับไม่ถ้วน เราเชื่อว่าการพัฒนานักฟุตบอลที่ดี ต้องดูแลทั้งฝีเท้าและร่างกายไปพร้อมกัน")

  showFoundersSection         Boolean @default(true)
  showFoundersSectionTitle    Boolean @default(true)
  foundersSectionTitle        String  @default("ผู้ก่อตั้งของเรา")
  showFoundersSectionSubtitle Boolean @default(true)
  foundersSectionSubtitle     String  @default("สองมืออาชีพ สองบทบาท ในสถาบันเดียว")

  showFounder1     Boolean @default(true)
  founder1Initials String  @default("ภย")
  founder1Role     String  @default("ผู้ก่อตั้ง / หัวหน้าโค้ช")
  founder1Name     String  @default("ภานุวัฒน์ ยินผัน")
  founder1Bio      String  @default("อดีตนักฟุตบอลทีมชาติไทย ติดทีมดาราเอเชีย (Asian All-Star) หลายสมัย ผันตัวมาถ่ายทอดความรู้และประสบการณ์การเล่นในระดับนานาชาติ เพื่อปั้นนักเตะเยาวชนรุ่นใหม่ให้เติบโตอย่างถูกวิธี ทั้งด้านเทคนิค ทัศนคติ และวินัยในสนาม")
  // Pre-existing committed static asset (public/images/panuwat-founder.jpg),
  // not the gitignored uploads folder — kept as the default so this real
  // photo doesn't silently disappear once this row starts getting created.
  founder1PhotoUrl String? @default("/images/panuwat-founder.jpg")

  showFounder2     Boolean @default(true)
  founder2Initials String  @default("PT")
  founder2Role     String  @default("ผู้ร่วมก่อตั้ง / หัวหน้านักกายภาพบำบัด")
  founder2Name     String  @default("ผู้ร่วมก่อตั้ง — นักกายภาพบำบัด")
  founder2Bio      String  @default("อดีตนักกายภาพบำบัดประจำทีมฟุตบอลหลายทีม สั่งสมประสบการณ์ดูแลนักกีฬาอาชีพ ปัจจุบันดูแลคลินิกกายภาพและฟื้นฟูของสถาบันโดยตรง เพื่อลดความเสี่ยงการบาดเจ็บและช่วยให้นักเรียนกลับมาเล่นได้อย่างปลอดภัย")
  founder2PhotoUrl String?

  showMissionSection Boolean @default(true)
  showMission1       Boolean @default(true)
  mission1Title      String  @default("พันธกิจของเรา")
  mission1Desc       String  @default("พัฒนานักฟุตบอลเยาวชนอย่างรอบด้าน ทั้งทักษะในสนามและสุขภาพร่างกาย ภายใต้การดูแลของผู้เชี่ยวชาญจริง")
  showMission2       Boolean @default(true)
  mission2Title      String  @default("แนวทางการสอน")
  mission2Desc       String  @default("ผสานประสบการณ์จริงจากสนามแข่งขันระดับนานาชาติ เข้ากับหลักวิทยาศาสตร์การกีฬาและกายภาพบำบัด")
  showMission3       Boolean @default(true)
  mission3Title      String  @default("ดูแลครบวงจร")
  mission3Desc       String  @default("ตั้งแต่การฝึกซ้อม การประเมินร่างกาย ไปจนถึงการฟื้นฟูอาการบาดเจ็บ ในสถาบันเดียว")

  showCtaSection Boolean @default(true)
  showCtaTitle   Boolean @default(true)
  ctaTitle       String  @default("มาร่วมเป็นส่วนหนึ่งของยินผัน ฟุตบอล อคาเดมี")
  ctaButtonLabel String  @default("สมัครเรียน")

  updatedAt DateTime @updatedAt

  @@map("about_page_content")
}

/// Singleton row (id is always "site") holding every editable text block in the
/// site-wide Header/Footer (src/components/Header.tsx, Footer.tsx), so admins
/// can update the brand name, nav labels, and contact/social info without a
/// code change. Defaults mirror the original hardcoded copy.
model SiteSettings {
  id String @id @default("site")

  // Logo image URL shown in Header/Footer in place of the built-in soccer-ball
  // icon (src/components/icons.tsx LogoMark). Null = use the built-in icon.
  // No file-upload system exists — admin pastes a hosted image URL, same
  // pattern as Article.coverImage. Default is the client-provided crest crop.
  logoUrl String? @default("/images/logo-mark.png")

  // Payment receiving details for the bank-transfer/PromptPay flow at
  // /pay/[bookingId] — all null until admin fills them in via
  // /admin/site-settings. Payment page shows "not configured yet" if empty.
  promptpayId       String?
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?

  headerBrandPrefix    String @default("ยินผัน ")
  headerBrandHighlight String @default("ฟุตบอล อคาเดมี")
  headerCtaLabel       String @default("สมัครเรียน")
  headerLoginLabel     String @default("เข้าสู่ระบบ")

  navHomeLabel    String @default("หน้าแรก")
  navAboutLabel   String @default("เกี่ยวกับเรา")
  navCoursesLabel String @default("คอร์สเรียน")
  navClinicLabel  String @default("คลินิกกายภาพ")
  navGalleryLabel String @default("แกลเลอรี่")
  navBlogLabel    String @default("บทความ")
  navContactLabel String @default("ติดต่อเรา")

  footerBrandName     String @default("ยินผัน ฟุตบอล อคาเดมี")
  footerDescription   String @default("สอนโดยทีมชาติ ฟื้นฟูโดยมืออาชีพ — สถาบันฟุตบอลที่ผสานการฝึกซ้อมและการดูแลร่างกายไว้ในที่เดียว")
  footerAddress       String @default("สนามฝึกซ้อม ยินผัน ฟุตบอล อคาเดมี")
  footerPhone         String @default("0XX-XXX-XXXX")
  footerLineId        String @default("@yinphanacademy")
  footerCoursesText   String @default("คอร์สเรียน")
  footerClinicText    String @default("คลินิกกายภาพ")
  footerFacebookText  String @default("Facebook (เร็วๆ นี้)")
  footerInstagramText String @default("Instagram (เร็วๆ นี้)")
  footerCopyrightText String @default("สงวนลิขสิทธิ์")

  contactHours String @default("จันทร์–อาทิตย์ 09:00–18:00 น.")

  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
