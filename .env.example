# Postgres (local dev via docker-compose)
POSTGRES_USER=football_academy
POSTGRES_PASSWORD=football_academy
POSTGRES_DB=football_academy
DATABASE_URL="postgresql://football_academy:football_academy@localhost:5432/football_academy?schema=public"

# NextAuth (Auth.js) — generate with `openssl rand -base64 32`
AUTH_SECRET=

# LINE Messaging API (leave blank until a real LINE Official Account channel is connected)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LINE_OA_ID=

# Email (Resend) — leave blank until a verified sending domain is connected
RESEND_API_KEY=

# Public site URL — used for SEO (sitemap, robots, canonical/OG URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
