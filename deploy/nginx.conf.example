# วางไฟล์นี้ที่ /etc/nginx/sites-available/football-academy บนเซิร์ฟเวอร์ Ubuntu
# แล้วสร้าง symlink:
#   sudo ln -s /etc/nginx/sites-available/football-academy /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# จากนั้นขอใบรับรอง SSL ด้วย Certbot (จะแก้ไฟล์นี้อัตโนมัติเพื่อเพิ่ม HTTPS ให้เอง):
#   sudo certbot --nginx -d yourdomain.com -d www.yourdomain.com
#
# ใช้ config เดียวกันได้ทั้ง 3 วิธีติดตั้ง (Docker / CI-CD / ไม่ใช้ Docker)
# เพราะทั้งสามวิธีสุดท้ายแล้วแอปจะฟังอยู่ที่ 127.0.0.1:3000 เหมือนกัน

server {
    listen 80;
    listen [::]:80;
    server_name yourdomain.com www.yourdomain.com;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
